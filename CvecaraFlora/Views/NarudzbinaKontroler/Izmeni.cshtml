@model CvecaraFlora.Modeli.Modeli.Narudzbina

@{
    ViewData["Title"] = "Izmena narudžbine";
}

<h1>Izmena narudžbine</h1>

@if (ViewBag.Greska != null)
{
    <div class="alert alert-danger">
        @ViewBag.Greska
    </div>
}

<form method="post">

    <input type="hidden" name="NarudzbinaID" value="@Model.NarudzbinaID" />

    <div class="mb-3">
        <label class="form-label">Ime i prezime kupca</label>
        <input type="text" name="ImePrezimeKupca" value="@Model.ImePrezimeKupca" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Broj telefona</label>
        <input type="text"
               name="BrojTelefona"
               value="@Model.BrojTelefona"
               class="form-control"
               pattern="^06[0-9]{7,8}$"
               minlength="9"
               maxlength="10"
               required
               title="Broj telefona mora početi sa 06 i imati 9 ili 10 cifara." />
    </div>

    <div class="mb-3">
        <label class="form-label">Datum preuzimanja</label>
        <input type="date" name="DatumPreuzimanja"
               value="@Model.DatumPreuzimanja.ToString("yyyy-MM-dd")"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label class="form-label">Tip aranžmana</label>
        <select name="TipAranzmanaID" class="form-control" required>
            @foreach (var tip in Model.TipoviAranzmana)
            {
                if (tip.TipAranzmanaID == Model.TipAranzmanaID)
                {
                    <option value="@tip.TipAranzmanaID" selected>@tip.Naziv</option>
                }
                else
                {
                    <option value="@tip.TipAranzmanaID">@tip.Naziv</option>
                }
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Ukupna cena</label>
        <input type="number" step="1" min="1" name="UkupnaCena"
               value="@Model.UkupnaCena.ToString("0")"
               class="form-control"
               required />
    </div>

    <button type="submit" class="btn btn-primary">
        Sačuvaj izmene
    </button>

</form>

<br />

<a href="/NarudzbinaKontroler/Index">
    Nazad na pregled
</a>